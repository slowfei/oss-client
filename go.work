go 1.25.0

use (
	./
	./examples/direct_grant_qiniu
	./examples/direct_grant_upyun
	./examples/multipart
	./examples/quickstart
	./examples/streaming_write
	./pkg/testkit/contract
	./providers/alibaba
	./providers/aws
	./providers/azure
	./providers/gcs
	./providers/huawei
	./providers/minio
	./providers/qiniu
	./providers/tencent
	./providers/upyun
	./providers/volcengine
)

// Workspace-level replace block: lets cross-module local-dev builds resolve
// in-repo deps to the on-disk modules even when the published tags
// (pkg/uos/v0.1.0, providers/<name>/v0.1.x) aren't yet on the proxy. Go 1.26
// workspace mode no longer auto-resolves transitive in-workspace deps without
// this hint when the required version is unpublished. These replaces are NOT
// part of any module's release surface — they live only in go.work and are
// not seen by downstream `go get` consumers (go.work is git-tracked but
// honored only inside this repo).
replace (
	github.com/slowfei/oss-client v0.2.2 => ./
	github.com/slowfei/oss-client/pkg/testkit/contract v0.2.2 => ./pkg/testkit/contract
	github.com/slowfei/oss-client/providers/alibaba v0.2.2 => ./providers/alibaba
	github.com/slowfei/oss-client/providers/aws v0.2.2 => ./providers/aws
	github.com/slowfei/oss-client/providers/azure v0.2.2 => ./providers/azure
	github.com/slowfei/oss-client/providers/gcs v0.2.2 => ./providers/gcs
	github.com/slowfei/oss-client/providers/huawei v0.2.2 => ./providers/huawei
	github.com/slowfei/oss-client/providers/minio v0.2.2 => ./providers/minio
	github.com/slowfei/oss-client/providers/qiniu v0.2.2 => ./providers/qiniu
	github.com/slowfei/oss-client/providers/tencent v0.2.2 => ./providers/tencent
	github.com/slowfei/oss-client/providers/upyun v0.2.2 => ./providers/upyun
	github.com/slowfei/oss-client/providers/volcengine v0.2.2 => ./providers/volcengine
)
